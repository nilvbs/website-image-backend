{
  "name": "website-image-backend",
  "version": "1.0.0",
  "description": "Backend service to upload images to S3 and return preview URLs",
  "type": "module",
  "main": "src/worker.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:worker": "wrangler dev",
    "setup:secrets": "node scripts/set-secrets.mjs",
    "deploy": "node scripts/deploy.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "wrangler": "^4.98.0"
  }
}
