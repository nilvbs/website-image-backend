PORT=3000

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-2
S3_BUCKET_NAME=vbs-website-image

# For Cloudflare deploy: add AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
# as Build secrets in the dashboard, and set Deploy command to: npm run deploy

# Optional: use a CloudFront or custom domain instead of the default S3 URL
# S3_PUBLIC_URL_PREFIX=https://d1234abcd.cloudfront.net
